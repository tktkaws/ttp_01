---
const sections = [
  { id: "section01", label: "私について" },
  { id: "section02", label: "略歴" },
  { id: "section03", label: "業務経歴" },
  { id: "section04", label: "アクセシビリティへの関心" },
  { id: "section05", label: "知的好奇心" },
  { id: "section06", label: "アウトプット" },
];
---

<nav class="mobile-nav" id="mobile-nav" aria-label="セクションナビゲーション">
  <button
    type="button"
    class="mobile-nav__trigger"
    aria-expanded="false"
    aria-haspopup="true"
    aria-label="ナビゲーションを開く"
  >
    <ul class="mobile-nav__indicator" aria-hidden="true">
      {sections.map(({ id }) => (
        <li class="mobile-nav__line" data-section={id} />
      ))}
    </ul>
  </button>
  <ul class="mobile-nav__menu" role="menu">
    {sections.map(({ id, label }) => (
      <li role="menuitem">
        <a href={`#${id}`} class="mobile-nav__link" data-section={id}>
          {label}
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .mobile-nav {
    position: fixed;
    bottom: calc(var(--spacing) * 2);
    right: calc(var(--spacing) * 2);
    z-index: 50;
  }

  @media (min-width: 640px) {
    .mobile-nav {
      bottom: calc(var(--spacing) * 4);
      right: calc(var(--spacing) * 4);
    }
  }

  @media (min-width: 768px) {
    .mobile-nav {
      display: none;
    }
  }

  .mobile-nav__trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border: none;
    background: transparent;
    cursor: pointer;
  }

  .mobile-nav__indicator {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .mobile-nav__line {
    width: 1.25rem;
    height: 2px;
    background: #d1d5db;
    border-radius: 1px;
    transition: background-color 0.2s;
  }

  .mobile-nav__line.is-active {
    background: #000;
  }

  :global(.dark) .mobile-nav__line {
    background: #4b5563;
  }

  :global(.dark) .mobile-nav__line.is-active {
    background: #fff;
  }

  .mobile-nav__menu {
    display: none;
    position: absolute;
    bottom: 100%;
    right: 0;
    margin-bottom: 0.5rem;
    padding: 0.25rem;
    border-radius: 0.5rem;
    border: 1px solid #d1d5db;
    background: #fff;
    list-style: none;
    min-width: 12rem;
  }

  :global(.dark) .mobile-nav__menu {
    border-color: #4b5563;
    background: #1f2937;
  }

  .mobile-nav__menu.is-open {
    display: block;
  }

  .mobile-nav__link {
    display: block;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    color: inherit;
    text-decoration: none;
  }

  .mobile-nav__link:hover,
  .mobile-nav__link:focus-visible {
    background: #f3f4f6;
  }

  :global(.dark) .mobile-nav__link:hover,
  :global(.dark) .mobile-nav__link:focus-visible {
    background: #374151;
  }

  .mobile-nav__link.is-active {
    font-weight: 700;
  }
</style>

<script>
  const nav = document.getElementById("mobile-nav")!;
  const trigger = nav.querySelector(".mobile-nav__trigger")!;
  const menu = nav.querySelector(".mobile-nav__menu")!;
  const lines = nav.querySelectorAll<HTMLElement>(".mobile-nav__line");
  const links = nav.querySelectorAll<HTMLAnchorElement>(".mobile-nav__link");

  // Toggle menu
  trigger.addEventListener("click", () => {
    const isOpen = menu.classList.toggle("is-open");
    trigger.setAttribute("aria-expanded", String(isOpen));
  });

  // Close on link click
  links.forEach((link) => {
    link.addEventListener("click", () => {
      menu.classList.remove("is-open");
      trigger.setAttribute("aria-expanded", "false");
    });
  });

  // Close on outside click
  document.addEventListener("click", (e) => {
    if (!nav.contains(e.target as Node)) {
      menu.classList.remove("is-open");
      trigger.setAttribute("aria-expanded", "false");
    }
  });

  // Intersection Observer for current section
  const sectionIds = Array.from(lines).map((line) => line.dataset.section!);
  const sections = sectionIds
    .map((id) => document.getElementById(id))
    .filter((el): el is HTMLElement => el !== null);

  let currentSection = sectionIds[0];

  function updateActive(id: string) {
    currentSection = id;
    lines.forEach((line) => {
      line.classList.toggle("is-active", line.dataset.section === id);
    });
    links.forEach((link) => {
      link.classList.toggle("is-active", link.dataset.section === id);
    });
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          updateActive(entry.target.id);
        }
      });
    },
    {
      rootMargin: "-20% 0px -60% 0px",
    }
  );

  sections.forEach((section) => observer.observe(section));

  // Init
  updateActive(currentSection);
</script>
